# Porta do backend
PORT=3001

# MySQL
DB_HOST=127.0.0.1
DB_USER=hotspotuser
DB_PASSWORD=GERADA_PELO_INSTALL
DB_NAME=hotspot

# JWT (gerar com: openssl rand -base64 48)
JWT_SECRET=GERADA_PELO_INSTALL

# Dominio do sistema (OBRIGATORIO - usado nos redirects do hotspot/MikroTik)
SYSTEM_DOMAIN=painel.seudominio.com.br

# WhatsApp / Evolution API
WHATSAPP_API_URL=https://mkt.seudominio.com.br
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=GERADA_PELO_INSTALL
EVOLUTION_INSTANCE=hotspot

# WireGuard
WG_HOST=SEU_IP_PUBLICO
WG_PASS=GERADA_PELO_INSTALL
WG_PANEL_PORT=51821
WG_EASY_URL=http://localhost:51821

# Fase 2 — operação e hardening
PROJECT_ROOT=/var/www/hotspot
BACKUPS_DIR=/var/www/hotspot/backups
BACKUP_LOG_PATH=/var/log/centerspot-backup.log
LOG_LEVEL=info
HELMET_ENABLED=1
AUDIT_ENABLED=1
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
UPDATE_SERVER_URL=
HEALTH_DISK_WARN_PERCENT=85
HEALTH_DISK_CRIT_PERCENT=95
UPLOAD_MAX_IMAGE_BYTES=10485760
UPLOAD_MAX_VIDEO_BYTES=52428800
UPLOAD_MAX_LOGO_BYTES=2097152
