# Copie para backend/.env.local (NÃO commitar .env.local)
# Uso: cd hotspot/backend && node scripts/mp-marketplace-smoke-test.js

# ── App Marketplace (integrador CenterSpot) ──
MP_MARKETPLACE_CLIENT_ID=
MP_MARKETPLACE_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=https://seu-dominio.com/api/mercadopago/oauth/callback

# ── Token do VENDEDOR (seller) — uma das opções ──
# Opção A: já obteve via OAuth (recomendado para smoke rápido)
MP_SELLER_ACCESS_TOKEN=

# Opção B: código one-time da URL de callback (?code=...)
# MP_OAUTH_CODE=

# Opção C: refresh (script troca por access_token)
# MP_OAUTH_REFRESH_TOKEN=

# ── Token MANUAL (conta sem OAuth) — teste erro 2059 ──
MP_MANUAL_ACCESS_TOKEN=

# ── Cartão (sandbox MP Brasil — cartão que aprova) ──
MP_SELLER_PUBLIC_KEY=
MP_TEST_PAYER_EMAIL=test_user_123456@testuser.com
MP_TEST_CARD_NUMBER=5031433215406351
MP_TEST_CARD_CVV=123
MP_TEST_CARD_EXP_MONTH=11
MP_TEST_CARD_EXP_YEAR=2030
MP_TEST_CARDHOLDER_NAME=APRO
MP_TEST_CARDHOLDER_CPF=12345678909

# ── Valores do teste (reais) ──
MP_TEST_AMOUNT=10.00
MP_APPLICATION_FEE=1.00

# ── Opcional ──
# MP_API_BASE=https://api.mercadopago.com
# MP_SKIP_PIX=0
# MP_SKIP_CARD=0
# MP_SKIP_MANUAL_2059=0
# MP_REPORT_DIR=reports
